# Application
ENVIRONMENT=development
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=dendridb
POSTGRES_PASSWORD=dendridb
POSTGRES_DB=dendridb

# Redis (working memory + Celery broker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
WORKING_MEMORY_BACKEND=redis

# Background jobs (Celery)
JOB_QUEUE_BACKEND=celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Set false when running the Celery worker for async jobs
CELERY_TASK_ALWAYS_EAGER=true

# Graph store (Neo4j — required for associations and traversal)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dendridb

# Embeddings
EMBEDDING_DIMENSIONS=384
EMBEDDING_MODEL=local-hash

# Forgetting and decay
DECAY_HALF_LIFE_HOURS=168
DECAY_MIN_SALIENCE=0.1
DECAY_MAX_SALIENCE=10.0
RETRIEVAL_STRENGTHEN_DELTA=0.1

# Docker Compose overrides (used by docker-compose.yml)
COMPOSE_PROJECT_NAME=dendridb
