# Application
ENVIRONMENT=development
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=dendridb
POSTGRES_PASSWORD=dendridb
POSTGRES_DB=dendridb

# Embeddings
EMBEDDING_DIMENSIONS=384
EMBEDDING_MODEL=local-hash

# Forgetting and decay
DECAY_HALF_LIFE_HOURS=168
DECAY_MIN_SALIENCE=0.1
DECAY_MAX_SALIENCE=10.0
RETRIEVAL_STRENGTHEN_DELTA=0.1

# Docker Compose overrides (used by docker-compose.yml)
COMPOSE_PROJECT_NAME=dendridb
